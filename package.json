{
	"name": "sokos-react-template",
	"version": "1.0.0",
	"description": "Mikrofrontend for Utbetalingsportalen",
	"type": "module",
	"scripts": {
		"dev": "vite --mode mock",
		"dev:backend": "vite --mode backend",
		"build": "tsc && vite build",
		"playwright": "playwright test",
		"biome:check": "biome check --files-ignore-unknown=true",
		"biome:fix": "biome check --write --no-errors-on-unmatched",
		"stylelint:check": "stylelint '**/*.css'",
		"stylelint:fix": "stylelint '**/*.css' --fix",
		"prepare": "husky",
		"pnpm:resolve": "node scripts/resolve-pnpm-version.mjs"
	},
	"dependencies": {
		"@grafana/faro-web-sdk": "2.7.0",
		"@navikt/aksel-icons": "7.39.0",
		"@navikt/ds-css": "7.39.0",
		"@navikt/ds-react": "7.39.0",
		"axios": "1.16.1",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"swr": "2.4.1",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@axe-core/playwright": "4.11.3",
		"@navikt/aksel-stylelint": "7.40.0",
		"@playwright/test": "1.60.0",
		"@types/node": "25.9.1",
		"@types/react": "19.2.16",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.2",
		"husky": "9.1.7",
		"lint-staged": "16.4.0",
		"msw": "2.14.6",
		"stylelint": "17.12.0",
		"stylelint-config-standard": "40.0.0",
		"typescript": "6.0.3",
		"vite": "8.0.16",
		"vite-plugin-css-injected-by-js": "5.0.1"
	},
	"msw": {
		"workerDirectory": [
			"public"
		]
	},
	"stylelint": {
		"extends": [
			"stylelint-config-standard",
			"@navikt/aksel-stylelint/recommended"
		],
		"ignoreFiles": "dist/**/*"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": "biome check --write --no-errors-on-unmatched",
		"*.css": "stylelint --fix"
	},
	"engines": {
		"pnpm": ">=11.5.2",
		"node": ">=24.14.1"
	},
	"packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916"
}
